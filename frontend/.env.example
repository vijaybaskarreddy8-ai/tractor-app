# Tractor Worker Hours Tracker - Environment Variables
# Copy this file to .env.local and fill in the values

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/tractor-hours?retryWrites=true&w=majority

# Google OAuth (create at https://console.cloud.google.com/apis/credentials)
# Callback URL: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# The ONLY email address allowed to use this app
AUTHORIZED_OWNER_EMAIL=your-email@gmail.com

# NextAuth secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your-secret-key-here
AUTH_SECRET=your-secret-key-here

# App URL
NEXTAUTH_URL=http://localhost:3000
